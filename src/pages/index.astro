---
import Layout from "../layouts/Layout.astro";
import Recipes from "../components/Recipes.vue";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content"; // 👈

const recipesEntries = await getCollection("recipes");
const recipesEntriesSorted = recipesEntries.sort((a: CollectionEntry<'recipes'>, b: CollectionEntry<'recipes'>) => // 👈
  a.data.title.localeCompare(b.data.title, "fr", {
    sensitivity: "base",
  })
);
---

<Layout title="Recettes de cuisine">
  <Recipes recipes={recipesEntriesSorted} client:load />
</Layout>
